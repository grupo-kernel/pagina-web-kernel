    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.2.0",
    "firebase": "^12.16.0",
    "jstat": "^1.9.6"
  }
}
